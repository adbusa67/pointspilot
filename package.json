{
  "name": "pointpilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PointPilot — track your travel reward points (Amex & Aeroplan) in one premium dashboard.",
  "scripts": {
    "dev": "vite",
    "server": "node --env-file=.env.local server/index.mjs",
    "dev:all": "concurrently -k -n backend,web -c magenta,cyan \"npm:server\" \"npm:dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.18",
    "concurrently": "^9.2.4",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "sqlite3@5.1.7": true
  }
}
